rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function getOrgMapping(orgId) {
      return get(/databases/$(database)/documents/userOrganizationMappings/$(request.auth.uid + '_' + orgId)).data;
    }

    function isOrgMember(orgId) {
      return isAuthenticated() && exists(/databases/$(database)/documents/userOrganizationMappings/$(request.auth.uid + '_' + orgId));
    }

    function isOrgAdmin(orgId) {
      return isOrgMember(orgId) && (getOrgMapping(orgId).role in ['owner', 'admin']);
    }

    function isOrgOwner(orgId) {
      return isOrgMember(orgId) && getOrgMapping(orgId).role == 'owner';
    }

    // Optimized project member check that takes project data as argument
    function isProjectMemberData(projectData) {
      return isOrgMember(projectData.organizationId) && 
             (request.auth.uid in projectData.members || isOrgAdmin(projectData.organizationId));
    }

    // For subcollections where we only have the ID
    function isProjectMemberId(projectId) {
      let project = get(/databases/$(database)/documents/projects/$(projectId)).data;
      return isProjectMemberData(project);
    }

    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        request.auth.token.email == "yuvanesh0107@gmail.com"
      );
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /organizationSettings/{orgId} {
      allow read: if isOrgMember(orgId);
      allow write: if isOrgAdmin(orgId);
    }

    match /taskStatuses/{statusId} {
      allow read: if isAuthenticated() && isOrgMember(resource.data.organizationId);
      allow create: if isAuthenticated() && isOrgAdmin(request.resource.data.organizationId);
      allow update: if isAuthenticated() && isOrgAdmin(resource.data.organizationId);
      allow delete: if isAuthenticated() && isOrgAdmin(resource.data.organizationId);
    }

    match /issueStatuses/{statusId} {
      allow read: if isAuthenticated() && isOrgMember(resource.data.organizationId);
      allow create: if isAuthenticated() && isOrgAdmin(request.resource.data.organizationId);
      allow update: if isAuthenticated() && isOrgAdmin(resource.data.organizationId);
      allow delete: if isAuthenticated() && isOrgAdmin(resource.data.organizationId);
    }

    match /userPreferences/{uid} {
      allow read, write: if isAuthenticated() && request.auth.uid == uid;
    }

    match /organizations/{orgId} {
      allow read: if isOrgMember(orgId);
      allow create: if isAuthenticated();
      allow update: if isOrgAdmin(orgId);
    }

    match /userOrganizationMappings/{mappingId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isOrgAdmin(resource.data.organizationId));
      allow create: if isAuthenticated(); 
      allow update: if isOrgAdmin(resource.data.organizationId);
      allow delete: if isOrgOwner(resource.data.organizationId);
    }

    match /invitations/{invitationId} {
      // Allow users to see their own invitations OR admins to see all in org
      allow read: if isAuthenticated() && (
        (request.auth.token.email != null && request.auth.token.email == resource.data.email) || 
        isOrgAdmin(resource.data.organizationId)
      );
      allow create: if isAuthenticated() && isOrgAdmin(request.resource.data.organizationId);
      allow update: if isAuthenticated() && (
        (request.auth.token.email != null && request.auth.token.email == resource.data.email) || 
        isOrgAdmin(resource.data.organizationId)
      );
      allow delete: if isAuthenticated() && isOrgAdmin(resource.data.organizationId);
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && request.auth.uid == userId;
    }

    match /projects/{projectId} {
      allow read: if isAuthenticated() && isProjectMemberData(resource.data);
      allow create: if isAuthenticated() && isOrgMember(request.resource.data.organizationId);
      allow update: if isAuthenticated() && isProjectMemberData(resource.data);
      allow delete: if isAuthenticated() && (
        resource.data.ownerId == request.auth.uid || 
        isOrgAdmin(resource.data.organizationId) || 
        isAdmin()
      );

      match /tasks/{taskId} {
        allow read, write: if isProjectMemberId(projectId);
        
        match /subtasks/{subtaskId} { allow read, write: if isProjectMemberId(projectId); }
        match /comments/{commentId} { allow read, write: if isProjectMemberId(projectId); }
        match /timeLogs/{logId} { allow read, write: if isProjectMemberId(projectId); }
      }

      match /{allSubcollections=**} {
        allow read, write: if isProjectMemberId(projectId);
      }
    }

    // Support for collectionGroup queries
    match /{path=**}/tasks/{taskId} {
      allow read: if isAuthenticated() && isOrgMember(resource.data.organizationId);
      allow write: if isAuthenticated() && (
        isOrgAdmin(resource.data.organizationId) || 
        (exists(/databases/$(database)/documents/projects/$(resource.data.projectId)) && 
         request.auth.uid in get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.members)
      );
    }

    match /{path=**}/timeLogs/{logId} {
      allow read: if isAuthenticated() && isOrgMember(resource.data.organizationId);
      allow write: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        isOrgAdmin(resource.data.organizationId)
      );
    }
    
    match /activityLogs/{logId} {
      allow read: if isAuthenticated() && (
        isOrgMember(resource.data.organizationId) || 
        resource.data.userId == request.auth.uid
      );
      allow create: if isAuthenticated();
    }
  }
}
